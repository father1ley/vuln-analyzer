{
  "manifest_version": 3,
  "name": "Tech Safety Extension",
  "description": "Scrapes site info, checks legitimacy, blocks JS redirects, and scans for potential backdoors.",
  "version": "1.0",
  "icons": {
    "16": "icons/icon16.png"
  },
 "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": ["<all_urls>"],
  "declarative_net_request": {
  "rule_resources": [
    {
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }
  ]
},

  "background": {
    "service_worker":"background/background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png"

    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/scrape.js",
        "content/redirect-blocker.js",
        "content/backdoor-scanner.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["styles/popup.css"],
      "matches": ["<all_urls>"]
    }
  ]
}